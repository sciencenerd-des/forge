# ─────────────────────────────────────────────────────────────────────────────
# Forge configuration — copy to .env and edit. Every value has a working default;
# nothing here is required to get started with the bundled docker-compose stack.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ────────────────────────────────────────────────────────────────────
# Writable home for state, logs, and per-project workspaces.
FORGE_HOME=~/.forge
# Where the loop creates each project's working directory.
# FORGE_WORKSPACES=~/.forge/workspaces
# SQLite gateway/state mirror + tool-docs DB (sane defaults under FORGE_HOME / repo).
# FORGE_STATE_DB=~/.forge/state.db
# FORGE_TOOLDOCS_DB=./tools_db/tool_docs.db

# ── Databases ────────────────────────────────────────────────────────────────
# Engine database — Postgres (the engine uses ARRAY columns). Matches docker-compose.
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge
# Control-plane (GUI) database — lightweight, SQLite by default.
# FORGE_CONTROL_DATABASE_URL=sqlite:///./forge-control.db

# ── Default project ──────────────────────────────────────────────────────────
# Pin a project UUID, or leave unset to resolve/create a "default" project.
# FORGE_DEFAULT_PROJECT=

# ── Model provider (any OpenAI-compatible backend) ───────────────────────────
# Defaults target a local LM Studio. Point these at Ollama, vLLM, or a cloud API.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=google/gemma-4-12b-qat
FORGE_LLM_API_KEY=not-needed
FORGE_LLM_TIMEOUT=300

# Per-role model routing (a coding specialist on the workers, a generalist on the
# rest). Each falls back to LLM_MODEL when unset.
# PGE_PLANNER_MODEL=
# PGE_EXECUTOR_MODEL=
# PGE_AUDITOR_MODEL=
# PGE_EVALUATOR_MODEL=
# PGE_STEWARD_MODEL=
# Per-role base_url override (e.g. a second server for the coder):
# FORGE_EXECUTOR_BASE_URL=http://localhost:1235/v1

# Example — cloud (OpenAI):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# FORGE_LLM_API_KEY=sk-...        # never commit a real key

# ── Loop control (advanced) ──────────────────────────────────────────────────
# PGE_MAX_TURNS=24                 # per-batch turn cap
# PGE_MAX_CONSECUTIVE_FAILURES=6   # batches survived (transient OR node-level) before giving up
# PGE_MAX_STAGNANT_BATCHES=2       # no-progress batches before stopping

# ── Control plane / web ──────────────────────────────────────────────────────
# FORGE_CONTROL_HOST=127.0.0.1
# FORGE_CONTROL_PORT=8787
# FORGE_CONTROL_URL=http://127.0.0.1:8787   # the web dev server proxies /api here
FORGE_CONTROL_TOKEN=forge-local-control

# Arbitrary model-proposed commands are disabled on the host by default. Prefer
# Docker. Set this only when you deliberately accept host filesystem access.
# FORGE_ALLOW_HOST_EXECUTION=1

# ── Slack bridge (forge slack) ───────────────────────────────────────────────
# Drive your LOCAL Hermes from a #hermesbot Slack channel via Slack Bolt in
# Socket Mode (no public URL / ngrok needed). Full setup guide:
#   integrations/slack/README.md
# Bot token (xoxb-…): OAuth & Permissions page after installing the app.
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token (xapp-…) with the connections:write scope — enables Socket Mode.
# SLACK_APP_TOKEN=xapp-your-app-level-token
# Channel the bridge watches (name without '#'). Default: hermesbot.
# SLACK_HERMES_CHANNEL=hermesbot
# Optional explicit channel id. If unset, the bridge resolves SLACK_HERMES_CHANNEL
# at startup and refuses to run if it cannot resolve the channel.
# SLACK_HERMES_CHANNEL_ID=C0123456789
# Optional comma-separated Slack user ids allowed to start/stop runs. If unset,
# any member who can post in the configured channel can use the bridge.
# SLACK_ALLOWED_USER_IDS=U0123456789,U0987654321
# The bridge talks to the control plane over HTTP — it reuses FORGE_CONTROL_URL
# and FORGE_CONTROL_TOKEN above, so make sure those are set and `forge serve` is
# running on the same machine.
